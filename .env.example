# =========================================================
# TMS - Environment Configuration
# Copy this file to ".env" and fill values for your server.
# Local dev (XAMPP) defaults are already set below.
# =========================================================

APP_NAME="TMS"
APP_ENV=local              # local | production
APP_DEBUG=true             # true on dev, false on production
APP_TIMEZONE=Asia/Manila

# Leave APP_URL empty to auto-detect from request (recommended for local).
# On Hostinger, set the full URL e.g. https://yourdomain.com
APP_URL=

# ---------------------------------------------------------
# DATABASE (MySQL / MariaDB)
# ---------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tms_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ---------------------------------------------------------
# SECURITY
# ---------------------------------------------------------
# Used for tokens / future API signing. Generate a long random string.
APP_KEY=
SESSION_LIFETIME=7200      # seconds (2 hours)
SESSION_NAME=tms_session

# ---------------------------------------------------------
# REST API (future-ready)
# ---------------------------------------------------------
API_PREFIX=/api/v1
API_RATE_LIMIT=60          # requests per minute
